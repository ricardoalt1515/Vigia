# Server-only environment variables — never prefix with NEXT_PUBLIC_
# Copy to .env.local and fill in values before running the console.
#
# End-to-end local run order:
#   1. make dev          — start Postgres + MinIO
#   2. make migrate-up   — apply goose migrations (includes River tables)
#   3. make seed-dev     — create demo tenant, debtor, 3 interactions; copy the printed key
#   4. go run ./cmd/api  — start the Go API server
#   5. make worker       — start the River worker (optional)
#   6. make console-install  — install npm dependencies (first time only)
#   7. VIGIA_API_KEY=<key from step 3> make console-dev
#   8. Open http://localhost:3000

VIGIA_API_KEY=
VIGIA_API_BASE_URL=http://localhost:8080
