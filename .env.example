# Copy to .env and fill in. internal/config validates these at startup.

APP_ENV=development
API_PORT=8080

# Database
DATABASE_URL=postgres://vigia:vigia@localhost:5432/vigia?sslmode=disable

# LLM (Anthropic) — judge
ANTHROPIC_API_KEY=
ANTHROPIC_JUDGE_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_TONE_MODEL=claude-sonnet-4-6

# Speech-to-text (pluggable; default whisper)
STT_PROVIDER=whisper
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=

# Object storage (WORM audio evidence) — MinIO locally
OBJECT_STORE_ENDPOINT=http://localhost:9000
OBJECT_STORE_ACCESS_KEY=vigia
OBJECT_STORE_SECRET_KEY=vigia-secret
OBJECT_STORE_BUCKET=vigia-evidence
OBJECT_STORE_REGION=us-east-1

# RFC 3161 trusted timestamp authority (free TSA)
TSA_URL=http://timestamp.digicert.com

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001
