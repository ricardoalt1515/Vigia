# Copy to .env for local issue #13 bootstrap.
# internal/config validates the required variables below at startup.

APP_ENV=development

# PostgreSQL local development database.
DATABASE_URL=postgres://vigia:vigia@localhost:5432/vigia?sslmode=disable

# S3-compatible local object storage readiness via MinIO.
# Issue #13 does not implement WORM/Object Lock enforcement, bucket lifecycle,
# audio evidence storage, or evidence ledger semantics.
OBJECT_STORE_ENDPOINT=http://localhost:9000
OBJECT_STORE_ACCESS_KEY=vigia
OBJECT_STORE_SECRET_KEY=vigia-secret
OBJECT_STORE_BUCKET=vigia-foundation
OBJECT_STORE_REGION=us-east-1

# Opt-in Bedrock Claude provider for the harness-demo CLI (issue #22).
# Not required for #13 tests/demos or the default `harness-demo` run: the demo CLI
# defaults to --provider fake (deterministic, no network). Only needed when running
# `harness-demo --provider bedrock`, which reads these two values directly via
# os.LookupEnv (not through internal/config) plus AWS credentials resolved from the
# standard AWS SDK credential chain (e.g. ~/.aws/credentials or AWS_ACCESS_KEY_ID/
# AWS_SECRET_ACCESS_KEY). Missing region, model id, or credentials fails fast.
AWS_REGION=
BEDROCK_MODEL_ID=
